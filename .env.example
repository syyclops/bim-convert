# BIM Convert environment variables
# Copy to .env.local for local development

# Mode: "local" (Azurite + mock converter) or "production"
BIM_ENV=local

# Azure Storage connection string (Azurite default shown)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;QueueEndpoint=http://127.0.0.1:10001/devstoreaccount1;

# Converter command ("bun run dev/mock-converter.ts" for local, or real exe path)
CONVERTER_CMD=bun run dev/mock-converter.ts

# Server port
PORT=8000

# Queue name
QUEUE_NAME=conversions

# Conversion timeout (ms) — 30 min default
CONVERSION_TIMEOUT_MS=1800000

# Stall timeout (ms) — kill converter if no output for this long (5 min default)
STALL_TIMEOUT_MS=300000

# Max file size (MB)
MAX_FILE_SIZE_MB=500

# Worker idle shutdown (ms) — 15 min default
IDLE_SHUTDOWN_MS=900000

# VM management (production only)
AZURE_RESOURCE_GROUP=
AZURE_SUBSCRIPTION_ID=
WORKER_VM_NAME=
