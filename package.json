{
  "name": "bim-convert",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "bun run dev/dev.ts",
    "dev:azurite": "azurite --silent --location dev/azurite-data --loose --skipApiVersionCheck",
    "dev:server": "bun --watch server.ts",
    "dev:worker": "bun --watch worker.ts",
    "dev:setup": "bun run dev/setup.ts",
    "test": "bun run tests/run.ts",
    "test:unit": "bun run tests/run.ts tests/unit/",
    "test:integration": "bun run tests/run.ts tests/integration/",
    "test:e2e": "bun run tests/run.ts tests/e2e/",
    "lint": "bun run tsc --noEmit",
    "deploy": "cd infra && terraform apply -auto-approve"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.26.0",
    "@azure/storage-queue": "^12.24.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "azurite": "^3.34.0"
  }
}
